#!/bin/sh

echo "🐶 Husky: Running fast checks before commit..."

# Run ESLint on the client
echo "▶ Linting client..."
cd apps/client && pnpm lint
if [ $? -ne 0 ]; then
  echo "❌ Client linting failed. Fix ESLint errors before committing."
  exit 1
fi

# Run backend Jest integration tests
echo "▶ Running backend tests..."
cd ../server && pnpm test
if [ $? -ne 0 ]; then
  echo "❌ Backend tests failed. Fix them before committing."
  exit 1
fi

echo "✅ All checks passed — committing."
