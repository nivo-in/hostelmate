{
  "name": "hostelmate",
  "version": "1.0.0",
  "description": "Hostel management platform by Nivo",
  "private": true,
  "scripts": {
    "predev": "kill -9 $(lsof -ti:3000,3001) 2>/dev/null || true",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "turbo": "latest"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=18"
  }
}
