{
  "name": "server",
  "version": "1.0.0",
  "description": "HostelMate API server by Nivo",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "test": "GROQ_API_KEY=test_key RAZORPAY_KEY_ID=test RAZORPAY_KEY_SECRET=test node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "GROQ_API_KEY=test_key RAZORPAY_KEY_ID=test RAZORPAY_KEY_SECRET=test node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "GROQ_API_KEY=test_key RAZORPAY_KEY_ID=test RAZORPAY_KEY_SECRET=test node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "packageManager": "pnpm@10.33.2",
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "collectCoverageFrom": [
      "src/routes/**/*.js",
      "src/config/geofence.js",
      "src/config/matcher.js",
      "src/config/validation.js",
      "!src/**/*.test.js"
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "@upstash/redis": "^1.38.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "openai": "^6.39.1",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}