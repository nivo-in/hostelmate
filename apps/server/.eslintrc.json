{
  "env": { "node": true, "es2022": true, "jest": true },
  "extends": ["eslint:recommended"],
  "parserOptions": { "ecmaVersion": 2022, "sourceType": "module" },
  "rules": {
    "no-unused-vars": "error",
    "no-console": "warn",
    "prefer-const": "error",
    "no-undef": "error"
  },
  "overrides": [
    {
      "files": ["**/__tests__/**"],
      "rules": {
        "no-unused-vars": "off",
        "no-console": "off"
      }
    }
  ]
}
