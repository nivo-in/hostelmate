# HostelMate — Root Environment Example
# Copy this file to apps/server/.env and apps/client/.env.local
# and fill in the values for your deployment.

# ─── Server (apps/server/.env) ──────────────────────────────────────────────

PORT=3001
NODE_ENV=development

# Supabase (https://supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Upstash Redis (https://console.upstash.com)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Hostel Geofence Coordinates (WGS84)
HOSTEL_LAT=12.9394941
HOSTEL_LNG=77.5669014

# Groq API — AI complaint classification (https://console.groq.com)
GROQ_API_KEY=gsk_your-groq-api-key

# Razorpay — Payment processing (https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Frontend URL — required in production for Socket.io CORS
# FRONTEND_URL=https://hostelmate.yourdomain.com

# ─── Client (apps/client/.env.local) ────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:3001
